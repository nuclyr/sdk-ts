{
  "name": "@nuclyr/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Nuclyr multi-cloud infrastructure platform",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "keywords": ["nuclyr", "multi-cloud", "aws", "gcp", "azure", "sdk"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nuclyr/sdk-ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-web": "^2.0.0",
    "@bufbuild/protobuf": "^2.0.0"
  }
}
